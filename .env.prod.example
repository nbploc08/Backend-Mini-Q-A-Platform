# --- QUAN TRỌNG: Đổi tất cả giá trị mặc định ---
POSTGRES_USER=core_prod
POSTGRES_PASSWORD=<strong-random-password>
POSTGRES_DB=coredb

JWT_SECRET=<random-string-64-chars>
JWT_REFRESH_EXPIRES_IN=2592000
INTERNAL_JWT_SECRET=<different-random-string-64-chars>
ENCRYPT_KEY=<random-string-32-chars>

REDIS_PASSWORD=<strong-random-password>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

NATS_URL=nats://nats:4222

# Database URLs dùng hostname Docker internal
DATABASE_URL_AUTH=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=auth
DATABASE_URL_CONTENT=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=content
DATABASE_URL_NOTIFICATION=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=notification
DATABASE_URL_GATEWAY=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=gateway

NODE_ENV=production
LOG_LEVEL=warn