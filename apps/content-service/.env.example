SERVICE_NAME=content-service
PORT=8003
LOG_LEVEL=info

# Database (Prisma)
DATABASE_URL="postgresql://core:corepass@localhost:5433/coredb?schema=content"

# NATS JetStream
NATS_URL=nats://localhost:4222

# JWT (verify forwarded user JWT)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ISSUER=auth-service
JWT_AUDIENCE=api

# Internal JWT (service-to-service)
INTERNAL_JWT_SECRET=your-internal-jwt-secret-change-in-production
INTERNAL_JWT_ISSUER=gateway
INTERNAL_JWT_AUDIENCE=internal

# Redis (rate limiter + permission cache)
REDIS_URL=redis://localhost:6379

# Auth-service URL (for RBAC permission fetching)
AUTH_SERVICE_URL=http://localhost:8001

CLOUD_NAME = xxx
CLOUD_API_KEY= xxxx
CLOUD_SECRET_KEY = xxxxxx