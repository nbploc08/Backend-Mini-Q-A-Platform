SERVICE_NAME=gateway
PORT=8000
LOG_LEVEL=info

# Database (Prisma)
DATABASE_URL="postgresql://core:corepass@localhost:5433/coredb?schema=gateway"

# NATS JetStream
NATS_URL=nats://localhost:4222

# User JWT (verify token issued by auth-service)
JWT_SECRET=your-jwt-secret-change-in-production
JWT_ISSUER=auth-service
JWT_AUDIENCE=api

# Auth-service URL (for internal calls) — default PORT in auth-service .env.example is 8001
AUTH_SERVICE_URL=http://localhost:8001

# Notification-service URL (for internal calls) — default PORT is 8002
NOTIFICATION_SERVICE_URL=http://localhost:8002

# Content-service URL (when gateway adds content client) — default PORT is 8003
CONTENT_SERVICE_URL=http://localhost:8003

# Internal JWT (sign when calling auth-service) — same as auth-service INTERNAL_JWT_*
INTERNAL_JWT_SECRET=your-internal-jwt-secret-change-in-production
INTERNAL_JWT_ISSUER=gateway
INTERNAL_JWT_AUDIENCE=internal

# Redis (rate limiter + permission cache)
REDIS_URL=redis://localhost:6379

# Shared secret for encrypt/decrypt
ENCRYPT_KEY=your-secret-key-min-16-chars
